# ─────────────────────────────────────────────────────────────
#  .env.example — Copy this to .env and fill your real keys
#  NEVER commit .env to GitHub — it's in .gitignore
# ─────────────────────────────────────────────────────────────

# Phase 1 — Phone lookup (free: 100 req/month)
# Get at: https://numverify.com
NUMVERIFY_KEY=your_numverify_key_here

# Phase 2 — IP geolocation (free: 50,000 req/month)
# Get at: https://ipinfo.io/signup
IPINFO_KEY=your_ipinfo_key_here

# Phase 3 — Email validation (free: 100 req/month)
# Get at: https://abstractapi.com
ABSTRACT_KEY=your_abstractapi_key_here

# Phase 4 — Breach check (~$3.50/month)
# Get at: https://haveibeenpwned.com/API/Key
HIBP_KEY=your_hibp_key_here

# Phase 5 — WHOIS lookup (free: 500 req/month)
# Get at: https://whoisxmlapi.com
WHOIS_KEY=your_whoisxmlapi_key_here
